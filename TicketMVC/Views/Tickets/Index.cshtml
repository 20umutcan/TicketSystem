@model IEnumerable<TicketMVC.Models.Ticket>
@{
    ViewData["Title"] = "Arıza Kayıtları";
    var products = ViewBag.Products as IEnumerable<TicketMVC.Models.Product> ?? new List<TicketMVC.Models.Product>();
    var categories = ViewBag.Categories as IEnumerable<TicketMVC.Models.Category> ?? new List<TicketMVC.Models.Category>();
}

<!-- All products as JSON for client-side filtering -->
<script id="allProductsJson" type="application/json">
@Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    products.Select(p => new { id = p.Id, name = p.Name, categoryId = p.CategoryId })
))
</script>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Aktif Arıza Kayıtları</h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">
        + Yeni Kayıt
    </button>
</div>

<!-- Quick Search Bar -->
<div class="mb-3">
    <input type="text" id="quickSearch" class="form-control form-control-sm"
           placeholder="&#128269; Müşteri adı, başlık veya telefon ile ara..." />
</div>

<div class="card shadow-sm">
    <div class="card-body p-2">
        <table id="ticketsTable" class="table table-sm table-hover table-bordered mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Öncelik</th>
                <th>Tekniker</th>
                    <th>Başlık</th>
                    <th>Müşteri</th>
                    <th>Telefon</th>
                    <th>Ürün</th>
                    <th>Durum</th>
                    <th>Tarih</th>
                    <th style="width:130px">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    var priorityBadge = t.Priority switch {
                        TicketMVC.Models.TicketPriority.Critical => "<span class='badge bg-danger'>KRİTİK</span>",
                        TicketMVC.Models.TicketPriority.High     => "<span class='badge bg-warning text-dark'>YÜKSEK</span>",
                        TicketMVC.Models.TicketPriority.Normal   => "<span class='badge bg-info text-dark'>NORMAL</span>",
                        TicketMVC.Models.TicketPriority.Low      => "<span class='badge bg-secondary'>DÜŞÜK</span>",
                        _ => ""
                    };
                    var statusBadge = t.Status switch {
                        TicketMVC.Models.TicketStatus.Open       => "<span class='badge bg-danger'>Açık</span>",
                        TicketMVC.Models.TicketStatus.InProgress => "<span class='badge bg-warning text-dark'>İşlemde</span>",
                        TicketMVC.Models.TicketStatus.Resolved   => "<span class='badge bg-primary'>Çözüldü</span>",
                        TicketMVC.Models.TicketStatus.Closed     => "<span class='badge bg-success'>Kapalı</span>",
                        _ => ""
                    };
                    var rowClass = t.Priority == TicketMVC.Models.TicketPriority.Critical ? "table-danger" : "";
                    <tr class="@rowClass">
                        <td>@t.Id</td>
                        <td>@Html.Raw(priorityBadge)</td>
                        <td>@(t.TechnicianName ?? "-")</td>
                        <td>@t.Title</td>
                        <td>@t.CustomerName</td>
                        <td>@(t.ContactPhone ?? "-")</td>
                        <td>@(t.Product?.Name ?? $"#{t.ProductId}")</td>
                        <td>@Html.Raw(statusBadge)</td>
                        <td>@t.CreatedDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <button class="btn btn-warning btn-xs edit-btn"
                                    data-id="@t.Id"
                                    data-title="@t.Title"
                                    data-description="@t.Description"
                                    data-customername="@t.CustomerName"
                                    data-contactphone="@t.ContactPhone"
                                    data-status="@((int)t.Status)"
                                    data-priority="@((int)t.Priority)" data-technicianname="@t.TechnicianName"
                                    data-productid="@t.ProductId" data-categoryname="@(t.Product?.Category?.Name)" data-productname="@(t.Product?.Name)"
                                    data-bs-toggle="modal" data-bs-target="#editModal">
                                Düzenle
                            </button>
                            <form asp-action="ToggleArchive" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@t.Id" />
                                <input type="hidden" name="currentlyArchived" value="false" />
                                <button type="submit" class="btn btn-secondary btn-xs" title="Arşivle">&#128230;</button>
                            </form>
                            <form asp-action="Delete" method="post" class="d-inline"
                                  onsubmit="return confirm('Kaydı kalıcı olarak silmek istiyor musunuz?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@t.Id" />
                                <button type="submit" class="btn btn-danger btn-xs">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h6 class="modal-title">Yeni Arıza Kaydı</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-2">
                        <div class="col-12">
                            <label for="addTitle" class="form-label">Başlık</label>
                            <input id="addTitle" name="Title" class="form-control form-control-sm" required maxlength="200"
                                   placeholder="Örn: Ekran açılmıyor, Wi-Fi bağlanamıyor..." />
                        </div>
                        <div class="col-md-6">
                            <label for="addCustomerName" class="form-label">Müşteri Adı</label>
                            <input id="addCustomerName" name="CustomerName" class="form-control form-control-sm" required maxlength="150"
                                   placeholder="Müşteri adı soyadı" />
                        </div>
                        <div class="col-md-6">
                            <label for="addContactPhone" class="form-label">İletişim Numarası</label>
                            <input id="addContactPhone" name="ContactPhone" type="tel" class="form-control form-control-sm" maxlength="30"
                                   pattern="^(0[\s]?\(?([0-9]{3})\)?[\s-]?([0-9]{3})[\s-]?([0-9]{4}))?$" 
                                   title="Geçerli bir telefon numarası giriniz (Örn: 0 555 555 5555)."
                                   placeholder="0 (5XX) XXX XX XX" />
                        </div>
                        <div class="col-md-6">
                            <label for="addCategoryId" class="form-label">Kategori</label>
                                                        <select id="addCategoryId" name="NewCategoryName" class="form-select form-select-sm select2-cat" required data-placeholder="Kategori seç / yaz">
                                <option value=""></option>
                                @foreach(var cat in categories)
                                {
                                    <option value="@(cat.Name)">@(cat.Name)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="addProductId" class="form-label">Ürün</label>
                                                        <select id="addProductId" name="NewProductName" class="form-select form-select-sm select2-prod" required data-placeholder="Ürün seç / yaz">
                                <option value=""></option>
                                @foreach(var p in products)
                                {
                                    <option value="@(p.Name)" data-category-name="@(categories.FirstOrDefault(c => c.Id == p.CategoryId)?.Name)">@(p.Name)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="addPriority" class="form-label">Öncelik</label>
                            <select id="addPriority" name="Priority" class="form-select form-select-sm">
                                <option value="0">Düşük</option>
                                <option value="1" selected>Normal</option>
                                <option value="2">Yüksek</option>
                                <option value="3">Kritik</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="addStatus" class="form-label">Durum</label>
                            <select id="addStatus" name="Status" class="form-select form-select-sm">
                                <option value="0" selected>Açık</option>
                                <option value="1">İşlemde</option>
                                <option value="2">Çözüldü</option>
                                <option value="3">Kapalı</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="addDescription" class="form-label">Açıklama / Arıza Detayı</label>
                            <textarea id="addDescription" name="Description" class="form-control form-control-sm" rows="3" maxlength="1000"
                                      placeholder="Arıza belirtileri, ne zaman başladı, ne denenildi..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary btn-sm">Kaydet</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editId" name="Id" />
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h6 class="modal-title">Arıza Kaydı Düzenle</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-2">
                        <div class="col-12">
                            <label for="editTitle" class="form-label">Başlık</label>
                            <input id="editTitle" name="Title" class="form-control form-control-sm" required maxlength="200" />
                        </div>
                        <div class="col-md-6">
                            <label for="editCustomerName" class="form-label">Müşteri Adı</label>
                            <input id="editCustomerName" name="CustomerName" class="form-control form-control-sm" required maxlength="150" />
                        </div>
                        <div class="col-md-6">
                            <label for="editContactPhone" class="form-label">İletişim Numarası</label>
                            <input id="editContactPhone" name="ContactPhone" type="tel" class="form-control form-control-sm" maxlength="30"
                                   pattern="^(0[\s]?\(?([0-9]{3})\)?[\s-]?([0-9]{3})[\s-]?([0-9]{4}))?$" 
                                   title="Geçerli bir telefon numarası giriniz (Örn: 0 555 555 5555)." />
                        </div>
                        <div class="col-md-6">
                            <label for="editCategoryId" class="form-label">Kategori</label>
                                                        <select id="editCategoryId" name="NewCategoryName" class="form-select form-select-sm select2-cat" required data-placeholder="Kategori seç / yaz">
                                <option value=""></option>
                                @foreach(var cat in categories)
                                {
                                    <option value="@(cat.Name)">@(cat.Name)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="editProductId" class="form-label">Ürün</label>
                                                        <select id="editProductId" name="NewProductName" class="form-select form-select-sm select2-prod" required data-placeholder="Ürün seç / yaz">
                                <option value=""></option>
                                @foreach(var p in products)
                                {
                                    <option value="@(p.Name)" data-category-name="@(categories.FirstOrDefault(c => c.Id == p.CategoryId)?.Name)">@(p.Name)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="editPriority" class="form-label">Öncelik</label>
                            <select id="editPriority" name="Priority" class="form-select form-select-sm">
                                <option value="0">Düşük</option>
                                <option value="1">Normal</option>
                                <option value="2">Yüksek</option>
                                <option value="3">Kritik</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="editStatus" class="form-label">Durum</label>
                            <select id="editStatus" name="Status" class="form-select form-select-sm">
                                <option value="0">Açık</option>
                                <option value="1">İşlemde</option>
                                <option value="2">Çözüldü</option>
                                <option value="3">Kapalı</option>
                            </select>
                        </div>
                                                  <div class="col-md-12">
                              <label for="editTechnicianName" class="form-label">Tekniker Adı</label>
                              <input id="editTechnicianName" name="TechnicianName" class="form-control form-control-sm" maxlength="100" placeholder="Kayıt açan tekniker" />
                          </div>
                        <div class="col-12">
                            <label for="editDescription" class="form-label">Açıklama</label>
                            <textarea id="editDescription" name="Description" class="form-control form-control-sm" rows="3" maxlength="1000"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-warning btn-sm">Güncelle</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    var allProducts = JSON.parse(document.getElementById('allProductsJson').textContent);

    jQuery(document).ready(function () {
        // Cache original products to avoid losing options on filter
        var allProductOptions = [];
        jQuery('#addProductId option').each(function() {
            if (jQuery(this).val()) {
                allProductOptions.push({
                    value: jQuery(this).val(),
                    text: jQuery(this).text(),
                    catName: jQuery(this).data('category-name')
                });
            }
        });

        jQuery('#addCategoryId').select2({ theme: 'bootstrap-5', tags: true, dropdownParent: jQuery('#addModal') });
        jQuery('#addProductId').select2({ theme: 'bootstrap-5', tags: true, dropdownParent: jQuery('#addModal') });
        jQuery('#editCategoryId').select2({ theme: 'bootstrap-5', tags: true, dropdownParent: jQuery('#editModal') });
        jQuery('#editProductId').select2({ theme: 'bootstrap-5', tags: true, dropdownParent: jQuery('#editModal') });

        jQuery('.select2-cat').on('change', function () {
            var selectedCat = jQuery(this).val();
            if (selectedCat) {
                selectedCat = selectedCat.toLowerCase();
            }
            var targetProdSelect = jQuery(this).closest('.modal-body').find('.select2-prod');
            var isAdd = jQuery(this).attr('id') === 'addCategoryId';
            var parentModal = jQuery(isAdd ? '#addModal' : '#editModal');
            
            var currentVal = targetProdSelect.val();

            // Clear options except placeholder
            targetProdSelect.empty().append('<option value=""></option>');
            
            // Re-populate options based on category filter
            allProductOptions.forEach(function(opt) {
                if (!selectedCat || (opt.catName && opt.catName.toLowerCase() === selectedCat)) {
                    var newOption = new Option(opt.text, opt.value, false, false);
                    jQuery(newOption).attr('data-category-name', opt.catName);
                    targetProdSelect.append(newOption);
                }
            });
            
            // Re-select if it was Custom tag, append it
            if (currentVal) {
                if(!targetProdSelect.find("option[value='" + currentVal + "']").length){
                    var customOption = new Option(currentVal, currentVal, true, true);
                    targetProdSelect.append(customOption);
                }
                targetProdSelect.val(currentVal).trigger('change.select2');
            }

            targetProdSelect.select2({
                theme: 'bootstrap-5',
                tags: true,
                dropdownParent: parentModal
            });
        });

        var table = jQuery('#ticketsTable').DataTable({
            order: [[0, 'desc']],
            pageLength: 25,
            dom: 'lrtip',
            language: { url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/tr.json' }
        });

        jQuery('#quickSearch').on('keyup', function () {
            table.search(jQuery(this).val()).draw();
        });

        jQuery('.edit-btn').on('click', function () {
            var catName = jQuery(this).data('categoryname');
            var prodName = jQuery(this).data('productname');

            jQuery('#editId').val(jQuery(this).data('id'));
            jQuery('#editTitle').val(jQuery(this).data('title'));
            jQuery('#editCustomerName').val(jQuery(this).data('customername'));
            jQuery('#editContactPhone').val(jQuery(this).data('contactphone'));
            jQuery('#editDescription').val(jQuery(this).data('description'));
            jQuery('#editStatus').val(jQuery(this).data('status'));
            jQuery('#editPriority').val(jQuery(this).data('priority'));
            jQuery('#editTechnicianName').val(jQuery(this).data('technicianname'));

            if (catName && !jQuery('#editCategoryId').find("option[value='" + catName + "']").length) {
                var newOption = new Option(catName, catName, true, true);
                jQuery('#editCategoryId').append(newOption);
            }
            jQuery('#editCategoryId').val(catName).trigger('change');

            if (prodName && !jQuery('#editProductId').find("option[value='" + prodName + "']").length) {
                var newOption = new Option(prodName, prodName, true, true);
                jQuery('#editProductId').append(newOption);
            }
            jQuery('#editProductId').val(prodName).trigger('change.select2');
        });

        jQuery('#addModal').on('hidden.bs.modal', function () {
            jQuery(this).find('form')[0].reset();
            jQuery(this).find('.select2-cat, .select2-prod').val(null).trigger('change');
        });
    });
</script>
}











