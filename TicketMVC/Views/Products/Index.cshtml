@model IEnumerable<TicketMVC.Models.Product>
@{
    ViewData["Title"] = "Ürünler";
    var categories = ViewBag.Categories as IEnumerable<TicketMVC.Models.Category> ?? new List<TicketMVC.Models.Category>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Ürün Listesi</h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">
        + Yeni Ürün
    </button>
</div>

<div class="card shadow-sm">
    <div class="card-body p-2">
        <table id="productsTable" class="table table-sm table-hover table-bordered mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Ürün Adı</th>
                    <th>Açıklama</th>
                    <th>Kategori</th>
                    <th style="width:120px">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr data-productid="@p.Id">
                        <td>@p.Id</td>
                        <td>@p.Name</td>
                        <td class="text-muted small">@(p.Description ?? "-")</td>
                        <td>@(p.Category?.Name ?? $"#{p.CategoryId}")</td>
                        <td>
                            <button class="btn btn-warning btn-xs edit-btn"
                                    data-id="@p.Id"
                                    data-name="@p.Name"
                                    data-description="@p.Description"
                                    data-categoryid="@p.CategoryId"
                                    data-bs-toggle="modal" data-bs-target="#editModal">
                                Düzenle
                            </button>
                            <form asp-action="Delete" method="post" class="d-inline"
                                  onsubmit="return confirm('ürünü silmek istiyor musunuz?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-danger btn-xs">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h6 class="modal-title">Yeni Ürün</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label for="addName" class="form-label">Ürün Adı</label>
                        <input id="addName" name="Name" class="form-control form-control-sm" required maxlength="100" />
                    </div>
                    <div class="mb-2">
                        <label for="addDescription" class="form-label">Açıklama</label>
                        <textarea id="addDescription" name="Description" class="form-control form-control-sm" rows="2" maxlength="300"></textarea>
                    </div>
                    <div class="mb-2">
                        <label for="addCategoryId" class="form-label">Kategori</label>
                        <select id="addCategoryId" name="CategoryId" class="form-select form-select-sm" required>
                            <option value="">-- Seçiniz --</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary btn-sm">Kaydet</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editId" name="Id" />
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h6 class="modal-title">Ürün Düzenle</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label for="editName" class="form-label">Ürün Adı</label>
                        <input id="editName" name="Name" class="form-control form-control-sm" required maxlength="100" />
                    </div>
                    <div class="mb-2">
                        <label for="editDescription" class="form-label">Açıklama</label>
                        <textarea id="editDescription" name="Description" class="form-control form-control-sm" rows="2" maxlength="300"></textarea>
                    </div>
                    <div class="mb-2">
                        <label for="editCategoryId" class="form-label">Kategori</label>
                        <select id="editCategoryId" name="CategoryId" class="form-select form-select-sm" required>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-warning btn-sm">Güncelle</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function () {
        var table = $('#productsTable').DataTable({
            language: { url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/tr.json' },
            columnDefs: [{ orderable: false, targets: [4] }]
        });

        // Edit modal populate
        $('#productsTable tbody').on('click', '.edit-btn', function () {
            $('#editId').val($(this).data('id'));
            $('#editName').val($(this).data('name'));
            $('#editDescription').val($(this).data('description'));
            $('#editCategoryId').val($(this).data('categoryid'));
        });
    });
</script>
}